# ===========================================
# RGR Benchmark Suite - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# This file is auto-loaded by DotNetEnv on API startup — no manual
# 'export' or 'source' commands are required.
# Environment variables and launchSettings.json override values from .env.

# AI Provider Selection
# Supported: openai, claude (or anthropic)
AI_PROVIDER=openai

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL=gpt-4o

# Anthropic/Claude Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Generation Configuration
# RGR_OUTPUT_DIR=./output

# AI Provider Tuning
# MAX_TOKENS=4096
